{
  "name": "slidecode",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "concurrently -n vite,term -c cyan,green \"vite\" \"node server/terminal-server.js\"",
    "dev:vite": "vite",
    "dev:terminal": "node server/terminal-server.js",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc -p tsconfig.src.json && tsc -p tsconfig.server.json",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:e2e && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dompurify": "^3.3.1",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.33",
    "marked": "^17.0.3",
    "mermaid": "^11.12.3",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "pnpm": {
    "overrides": {
      "dompurify": "^3.3.2"
    }
  }
}
